<UserControl
    x:Class="PicView.Avalonia.Views.Config.ZoomSettingsView"
    x:DataType="viewModels:CoreViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:ui="clr-namespace:PicView.Avalonia.UI"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel HorizontalAlignment="Center" Orientation="Vertical">

        <StackPanel Classes="searchHeader">
            <Image
                Height="18"
                Source="{StaticResource ZoomImage}"
                Width="18" />
            <TextBlock
                Classes="txt bold"
                Margin="0,20,0,20"
                Text="{CompiledBinding Translation.Zoom.Value,
                                       Mode=OneWay}" />
        </StackPanel>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.ZoomResetSearchTags.Value}">
            <customControls:TextToggleButton
                Classes="altHover settingsToggleButton"
                IsChecked="{CompiledBinding SettingsViewModel.IsResettingZoomOnImageChange.Value}"
                Text="{CompiledBinding Translation.ResetZoomOnChange.Value,
                                       Mode=OneWay}"
                x:Name="ResetZoomToggleButton" />
        </Border>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.ZoomOutSearchTags.Value}">
            <customControls:TextToggleButton
                Classes="altHover settingsToggleButton"
                IsChecked="{CompiledBinding SettingsViewModel.IsAvoidingZoomingOut.Value}"
                Text="{CompiledBinding Translation.AllowZoomOut.Value,
                                       Mode=OneWay}"
                x:Name="AllowZoomOutToggleButton" />
        </Border>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.ZoomAnimationSearchTags.Value}">
            <customControls:TextToggleButton
                Classes="altHover settingsToggleButton"
                IsChecked="{CompiledBinding SettingsViewModel.IsZoomAnimated.Value}"
                Text="{CompiledBinding Translation.UseAnimatedZoom.Value,
                                       Mode=OneWay}"
                x:Name="UseAnimatedZoomToggleButton" />
        </Border>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.ZoomPopupSearchTags.Value}">
            <customControls:TextToggleButton
                Classes="altHover settingsToggleButton"
                IsChecked="{CompiledBinding SettingsViewModel.IsShowingZoomPercentagePopup.Value}"
                Text="{CompiledBinding Translation.ShowZoomPercentagePopup.Value,
                                       Mode=OneWay}"
                x:Name="ShowZoomPercentageToggleButton" />
        </Border>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.ZoomSpeedSearchTags.Value}">
            <StackPanel>
                <TextBlock
                    Classes="txt"
                    FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                    FontSize="12"
                    Margin="0,10,0,10"
                    MaxWidth="300"
                    Text="{CompiledBinding Translation.AdjustTimingForZoom.Value,
                                           Mode=OneWay}" />
                <customControls:CustomSlider
                    Height="30"
                    HorizontalAlignment="Center"
                    IsSnapToTickEnabled="True"
                    Margin="0,1,0,1"
                    Maximum="1.5"
                    Minimum=".1"
                    TickFrequency=".05"
                    TickPlacement="BottomRight"
                    Value="{CompiledBinding SettingsViewModel.ZoomSpeed.Value}"
                    Width="300" />

                <TextBlock
                    Classes="txt"
                    FontFamily="/Assets/Fonts/Roboto-Bold.ttf#Roboto"
                    Margin="0,0,0,15"
                    Text="{CompiledBinding SettingsViewModel.GetZoomSpeed.Value,
                                           Mode=OneWay}" />
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>