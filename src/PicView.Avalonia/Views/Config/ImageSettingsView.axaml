<UserControl
    x:Class="PicView.Avalonia.Views.Config.ImageSettingsView"
    x:DataType="viewModels:CoreViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:ui="clr-namespace:PicView.Avalonia.UI"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel HorizontalAlignment="Center" Orientation="Vertical">

        <StackPanel Classes="searchHeader">
            <Image
                Height="18"
                Source="{StaticResource ImageSettingImage}"
                Width="18" />
            <TextBlock
                Classes="txt bold"
                Margin="0,20,0,20"
                Text="{CompiledBinding Translation.Image.Value,
                                       Mode=OneWay}" />
        </StackPanel>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.ImageStretchSearchTags}">
            <customControls:TextToggleButton
                Classes="altHover settingsToggleButton"
                IsChecked="{CompiledBinding MainWindows.ActiveWindow.Value.IsStretched.Value}"
                Text="{CompiledBinding Translation.Stretch.Value,
                                       Mode=OneWay}"
                ToolTip.Tip="{CompiledBinding Translation.Stretch.Value,
                                              Mode=OneWay}"
                x:Name="StretchToggleButton" />
        </Border>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.ImageScrollingSearchTags}">
            <customControls:TextToggleButton
                Classes="altHover settingsToggleButton"
                Command="{CompiledBinding MainWindows.ActiveWindow.Value.ToggleScrollCommand}"
                IsChecked="{CompiledBinding MainWindows.ActiveWindow.Value.IsScrollingEnabled.Value}"
                Text="{CompiledBinding Translation.IsScrolling.Value,
                                       Mode=OneWay}"
                x:Name="ScrollToggleButton" />
        </Border>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.ImageSideBySideSearchTags}">
            <customControls:TextToggleButton
                Classes="altHover settingsToggleButton"
                Command="{CompiledBinding MainWindows.ActiveWindow.Value.SideBySideCommand}"
                Text="{CompiledBinding Translation.SideBySide.Value,
                                       Mode=OneWay}"
                x:Name="SideBySideToggleButton" />

        </Border>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.ImageScalingSearchTags}">
            <StackPanel>
                <TextBlock
                    Classes="txt bold"
                    Margin="0,20,0,20"
                    Text="{CompiledBinding Translation.ImageAliasing.Value,
                                           Mode=OneWay}" />
                <ComboBox
                    Background="{DynamicResource SecondaryBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="1"
                    FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                    Foreground="{DynamicResource MainTextColor}"
                    Margin="0,6,0,10"
                    Padding="5,7,0,7"
                    SelectedIndex="{CompiledBinding SettingsViewModel.ImageScalingIndex.Value,
                                                    Mode=TwoWay}"
                    Width="300"
                    x:Name="ImageAliasingBox">
                    <ComboBoxItem Content="{CompiledBinding Translation.HighQuality.Value, Mode=OneWay}" Foreground="{DynamicResource MainTextColor}" />
                    <ComboBoxItem Content="{CompiledBinding Translation.None.Value, Mode=OneWay}" Foreground="{DynamicResource MainTextColor}" />
                </ComboBox>
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>