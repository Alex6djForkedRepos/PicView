<UserControl
    x:Class="PicView.Avalonia.Views.Config.FileAssociationsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="clr-namespace:PicView.Avalonia.UI"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="viewModels:CoreViewModel"
    Focusable="True"
    mc:Ignorable="d">
    <StackPanel HorizontalAlignment="Center">

        <Border ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.KeybindingsSearchTags}" Classes="searchBorder">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <Image
                        Width="18"
                        Height="18"
                        Source="{StaticResource FileAssociationImage}" />
                    <TextBlock
                        Margin="0,20,0,20"
                        Classes="txt bold searchHeader"
                        Text="{CompiledBinding Translation.FileAssociations.Value,
                                               Mode=OneWay}" />
                </StackPanel>
                <customControls:TextIconButton
                    x:Name="KeyBindingsButton"
                    Width="300"
                    Padding="6"
                    HorizontalAlignment="Center"
                    Background="{DynamicResource SecondaryBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="1"
                    Classes="altHover"
                    Command="{Binding MainWindows.ActiveWindow.Value.FileAssociationsWindowCommand}"
                    CornerRadius="4"
                    Icon="{StaticResource FileAssociationImage}"
                    IconHeight="18"
                    IconMargin="5,5,10,5"
                    IconWidth="18"
                    Text="{Binding Translation.FileAssociations.Value}" />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
