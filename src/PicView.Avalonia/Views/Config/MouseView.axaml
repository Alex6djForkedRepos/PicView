<UserControl
    x:Class="PicView.Avalonia.Views.Config.MouseView"
    x:DataType="viewModels:CoreViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:ui="clr-namespace:PicView.Avalonia.UI"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel HorizontalAlignment="Center">

        <StackPanel Classes="searchHeader">
            <Image
                Height="18"
                Source="{StaticResource MouseWheelIcon}"
                Width="18" />
            <TextBlock
                Classes="txt bold"
                Margin="0,20,0,20"
                Text="{CompiledBinding Translation.Mouse.Value,
                                       Mode=OneWay}" />
        </StackPanel>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.MouseDoubleClickSearchTags.Value}">
            <StackPanel>
                <TextBlock
                    Classes="txt bold"
                    Margin="0,20,0,20"
                    Text="{CompiledBinding Translation.DoubleClick.Value,
                                           Mode=OneWay}" />

                <ComboBox
                    Background="{DynamicResource SecondaryBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="1"
                    FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                    Foreground="{DynamicResource MainTextColor}"
                    ItemsSource="{CompiledBinding SettingsViewModel.MouseDoubleClickBehaviors.Value}"
                    Margin="0,6,0,15"
                    Padding="5,7,0,7"
                    SelectedIndex="{CompiledBinding SettingsViewModel.MouseDoubleClickBehaviorIndex.Value}"
                    Width="300"
                    x:Name="DoubleClickBox" />
            </StackPanel>
        </Border>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.MouseNavigationSearchTags.Value}">
            <StackPanel>
                <TextBlock
                    Classes="txt bold"
                    Margin="0,20,0,20"
                    Text="{CompiledBinding Translation.MouseSideButtons.Value,
                                           Mode=OneWay}" />

                <ComboBox
                    Background="{DynamicResource SecondaryBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="1"
                    FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                    Foreground="{DynamicResource MainTextColor}"
                    Margin="0,6,0,15"
                    Padding="5,7,0,7"
                    SelectedIndex="{CompiledBinding SettingsViewModel.MouseSideButtonBehavior.Value,
                                                    Mode=TwoWay}"
                    Width="300"
                    x:Name="MouseSideButtonBox">
                    <ComboBoxItem Content="{CompiledBinding Translation.NavigateFileHistory.Value, Mode=OneWay}" Foreground="{DynamicResource MainTextColor}" />
                    <ComboBoxItem Content="{CompiledBinding Translation.NavigateBetweenDirectories.Value, Mode=OneWay}" Foreground="{DynamicResource MainTextColor}" />
                    <ComboBoxItem Content="{CompiledBinding Translation.None.Value, Mode=OneWay}" Foreground="{DynamicResource MainTextColor}" />
                </ComboBox>
            </StackPanel>
        </Border>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.MouseWheelBehaviorSearchTags.Value}">
            <StackPanel>
                <TextBlock
                    Classes="txt bold"
                    Margin="0,20,0,20"
                    Text="{CompiledBinding Translation.MouseWheel.Value,
                                           Mode=OneWay}" />

                <ComboBox
                    Background="{DynamicResource SecondaryBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="1"
                    FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                    Foreground="{DynamicResource MainTextColor}"
                    Margin="0,6,0,15"
                    Padding="5,7,0,7"
                    SelectedIndex="{CompiledBinding SettingsViewModel.MouseWheelBehavior.Value,
                                                    Mode=TwoWay}"
                    Width="300"
                    x:Name="MouseWheelBox">
                    <ComboBoxItem Content="{CompiledBinding Translation.CtrlToZoom.Value, Mode=OneWay}" Foreground="{DynamicResource MainTextColor}" />
                    <ComboBoxItem Content="{CompiledBinding Translation.ScrollToZoom.Value, Mode=OneWay}" Foreground="{DynamicResource MainTextColor}" />
                </ComboBox>
            </StackPanel>
        </Border>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.MouseScrollDirectionSearchTags.Value}">
            <StackPanel>
                <TextBlock
                    Classes="txt bold"
                    Margin="0,10,0,10"
                    MaxWidth="300"
                    Text="{CompiledBinding Translation.ScrollDirection.Value,
                                           Mode=OneWay}" />
                <ComboBox
                    Background="{DynamicResource SecondaryBackgroundColor}"
                    BorderBrush="{DynamicResource MainBorderColor}"
                    BorderThickness="1"
                    FontFamily="/Assets/Fonts/Roboto-Medium.ttf#Roboto"
                    Foreground="{DynamicResource MainTextColor}"
                    Margin="0,6,0,15"
                    Padding="5,7,0,7"
                    SelectedIndex="{CompiledBinding SettingsViewModel.ScrollDirectionIndex.Value,
                                                    Mode=TwoWay}"
                    Width="300"
                    x:Name="ScrollDirectionBox">
                    <ComboBoxItem Content="{CompiledBinding Translation.Reverse.Value, Mode=OneWay}" Foreground="{DynamicResource MainTextColor}" />
                    <ComboBoxItem Content="{CompiledBinding Translation.Forward.Value, Mode=OneWay}" Foreground="{DynamicResource MainTextColor}" />
                </ComboBox>
            </StackPanel>
        </Border>

        <Border Classes="searchBorder" ui:SearchProperties.Keywords="{CompiledBinding SettingsViewModel.SearchData.MouseTouchpadSearchTags.Value}">
            <StackPanel>
                <customControls:TextIconButton
                    Classes="altHover settingsTextIconButton"
                    Command="{CompiledBinding SettingsViewModel.ToggleUsingTouchpadCommand}"
                    Icon="{StaticResource TouchPadImage}"
                    IconHeight="18"
                    IconMargin="10,0,10,0"
                    IconWidth="18"
                    IsVisible="{CompiledBinding SettingsViewModel.IsUsingTouchpad.Value}"
                    Text="{CompiledBinding Translation.IsUsingTouchpad.Value,
                                           Mode=OneWay}"
                    TextMargin="0,1,5,0"
                    TextMaxWidth="240"
                    x:Name="TouchPadButton" />
                <customControls:TextIconButton
                    Classes="altHover settingsTextIconButton"
                    Command="{CompiledBinding SettingsViewModel.ToggleUsingTouchpadCommand}"
                    Icon="{StaticResource MouseWheelIcon}"
                    IconHeight="18"
                    IconMargin="10,0,10,0"
                    IconWidth="18"
                    IsVisible="{CompiledBinding !SettingsViewModel.IsUsingTouchpad.Value}"
                    Text="{CompiledBinding Translation.IsUsingTouchpad.Value,
                                           Mode=OneWay}"
                    TextMargin="0,1,5,0"
                    TextMaxWidth="240"
                    x:Name="MouseButton" />
            </StackPanel>
        </Border>

    </StackPanel>
</UserControl>