<ContextMenu
    x:Class="PicView.Avalonia.Views.UC.RotationContextMenu"
    x:DataType="vm:MainWindowViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:vm="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <MenuItem
        Command="{Binding Rotate0Command}"
        GroupName="RotationGroup"
        Header="0°"
        ToggleType="Radio"
        x:Name="Rotation0Item" />
    <MenuItem
        Command="{Binding Rotate90Command}"
        GroupName="RotationGroup"
        Header="90°"
        ToggleType="Radio"
        x:Name="Rotation90Item" />
    <MenuItem
        Command="{Binding Rotate180Command}"
        GroupName="RotationGroup"
        Header="180°"
        ToggleType="Radio"
        x:Name="Rotation180Item" />
    <MenuItem
        Command="{Binding Rotate270Command}"
        GroupName="RotationGroup"
        Header="270°"
        ToggleType="Radio"
        x:Name="Rotation270Item" />
    <Separator />
    <MenuItem Command="{CompiledBinding FlipCommand}" Header="{CompiledBinding Translation.IsFlipped.Value}">
        <MenuItem.Icon>
            <Path
                Data="{StaticResource FlipGeometry}"
                Fill="{DynamicResource MainTextColor}"
                Height="12"
                Stretch="Fill"
                Width="12">
                <Path.RenderTransform>
                    <ScaleTransform ScaleX="{CompiledBinding WindowTabs.ActiveTab.Value.ScaleX.Value}" />
                </Path.RenderTransform>
            </Path>
        </MenuItem.Icon>
    </MenuItem>
</ContextMenu>
