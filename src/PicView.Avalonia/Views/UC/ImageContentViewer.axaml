<UserControl
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d"
    x:Class="PicView.Avalonia.Views.UC.ImageContentViewer"
    x:DataType="vm:MainViewModel"
    xmlns="https://github.com/avaloniaui"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:gallery="clr-namespace:PicView.Avalonia.Views.Gallery"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:uc="clr-namespace:PicView.Avalonia.Views.UC"
    xmlns:vm="clr-namespace:PicView.Avalonia.ViewModels"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SplitView
        DisplayMode="CompactInline"
        IsPaneOpen="{CompiledBinding Gallery.IsBottomGalleryShown}"
        PanePlacement="Bottom">
        <SplitView.Pane>
            <gallery:GalleryAnimationControlView
                GalleryMode="{CompiledBinding Gallery.GalleryMode.Value,
                                              Mode=OneWay}"
                Height="NaN"
                IsVisible="{CompiledBinding Gallery.IsBottomGalleryShown.Value,
                                            Mode=OneWay}"
                VerticalAlignment="{CompiledBinding Gallery.GalleryVerticalAlignment.Value,
                                                    Mode=OneWay}"
                Width="{CompiledBinding PicViewer.GalleryWidth.Value,
                                        Mode=OneWay}"
                x:Name="GalleryView" />
        </SplitView.Pane>
        <SplitView
            DisplayMode="CompactInline"
            Height="{CompiledBinding PicViewer.ImageHeight.Value}"
            IsPaneOpen="{CompiledBinding PicViewer.IsShowingSideBySide.Value}"
            PanePlacement="Right">
            <SplitView.Pane>
                <uc:ImageViewer Width="{CompiledBinding PicViewer.SecondaryImageWidth.Value}" />
            </SplitView.Pane>
            <uc:ImageViewer Width="{CompiledBinding PicViewer.ImageWidth.Value}" />
        </SplitView>

    </SplitView>
</UserControl>