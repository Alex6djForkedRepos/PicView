<customControls:NavigateAbleItem
    x:Class="PicView.Avalonia.Views.Gallery.GalleryItem"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:customControls="clr-namespace:PicView.Avalonia.CustomControls"
    xmlns:gallery="clr-namespace:PicView.Avalonia.Views.Gallery"
    xmlns:gallerySettings="clr-namespace:PicView.Core.Gallery;assembly=PicView.Core"
    xmlns:viewModels="clr-namespace:PicView.Core.ViewModels;assembly=PicView.Core"
    x:DataType="viewModels:GalleryItemViewModel"
    Background="{DynamicResource MenuBackgroundColor}"
    CornerRadius="4">
    <Border
        Width="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.ItemWidth.Value,
                                Mode=OneWay}"
        Height="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.ItemHeight.Value,
                                 Mode=OneWay}"
        MinWidth="25"
        MinHeight="25"
        CornerRadius="4"
        ToolTip.HorizontalOffset="0"
        ToolTip.Placement="TopEdgeAlignedLeft"
        ToolTip.VerticalOffset="0">
        <customControls:ThumbImage
            x:Name="GalleryImage"
            Source="{CompiledBinding Image.Value}"
            Stretch="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.GalleryStretch.Value}" />
        <ToolTip.Tip>
            <StackPanel MaxWidth="600">
                <TextBlock
                    x:Name="FileName"
                    Margin="2,0,2,6"
                    Classes="txt bold"
                    Foreground="{DynamicResource MainTextColor}"
                    Text="{CompiledBinding FileName.Value}"
                    TextWrapping="NoWrap" />
                <TextBlock
                    x:Name="FileLocation"
                    Margin="2,0,2,2"
                    Classes="txt"
                    Text="{CompiledBinding FileLocation.Value}"
                    TextWrapping="NoWrap" />
                <TextBlock
                    x:Name="FileSize"
                    Margin="2,0,2,2"
                    Classes="txt"
                    Text="{CompiledBinding FileSize.Value}"
                    TextWrapping="NoWrap" />
                <TextBlock
                    x:Name="FileDate"
                    Margin="2,0,2,4"
                    Classes="txt"
                    Text="{CompiledBinding FileDate.Value}"
                    TextWrapping="NoWrap" />
            </StackPanel>
        </ToolTip.Tip>
        <Border.ContextMenu>
            <ContextMenu x:Name="GalleryContextMenu">

                <!--  Open with  -->
                <MenuItem
                    x:Name="OpenWith"
                    Click="OpenWith_OnClick"
                    Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.OpenWith.Value,
                                             Mode=OneWay}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource OpenExternalImage}" />
                    </MenuItem.Icon>
                </MenuItem>

                <!--  Locate on disk  -->
                <MenuItem
                    x:Name="LocateOnDisk"
                    Click="LocateOnDisk_OnClick"
                    Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.ShowInFolder.Value,
                                             Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path Classes="ShowInFolderPath" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />

                <!--  Set as wallpaper  -->
                <MenuItem x:Name="WallpaperMenuItem" Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.SetAsWallpaper.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path
                            Width="13"
                            Height="10.40"
                            Data="{StaticResource PanoramaGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Stretch="Fill" />
                    </MenuItem.Icon>

                    <!--  Set as wallpaper filled  -->
                    <MenuItem
                        x:Name="WallpaperFilled"
                        Click="WallpaperFilled_OnClick"
                        Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Fill.Value,
                                                 Mode=OneWay}">
                        <MenuItem.Icon>
                            <Path
                                Width="13"
                                Height="10.40"
                                Data="{StaticResource PanoramaGeometry}"
                                Fill="{DynamicResource MainTextColor}"
                                Stretch="Fill" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Set as wallpaper fit  -->
                    <MenuItem
                        x:Name="WallpaperFitted"
                        Click="WallpaperFitted_OnClick"
                        Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Fit.Value,
                                                 Mode=OneWay}">
                        <MenuItem.Icon>
                            <Path
                                Width="13"
                                Height="10.40"
                                Data="{StaticResource PanoramaGeometry}"
                                Fill="{DynamicResource MainTextColor}"
                                Stretch="Fill" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Set as wallpaper stretched  -->
                    <MenuItem
                        x:Name="WallpaperStretched"
                        Click="WallpaperStretched_OnClick"
                        Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Stretch.Value,
                                                 Mode=OneWay}">
                        <MenuItem.Icon>
                            <Path
                                Width="13"
                                Height="10.40"
                                Data="{StaticResource PanoramaGeometry}"
                                Fill="{DynamicResource MainTextColor}"
                                Stretch="Fill" />
                        </MenuItem.Icon>
                    </MenuItem>


                    <!--  Set as wallpaper centered  -->
                    <MenuItem
                        x:Name="WallpaperCentered"
                        Click="WallpaperCentered_OnClick"
                        Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Center.Value,
                                                 Mode=OneWay}">
                        <MenuItem.Icon>
                            <Path
                                Width="13"
                                Height="10.40"
                                Data="{StaticResource PanoramaGeometry}"
                                Fill="{DynamicResource MainTextColor}"
                                Stretch="Fill" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <!--  Set as wallpaper tiled  -->
                    <MenuItem
                        x:Name="WallpaperTiled"
                        Click="WallpaperTiled_OnClick"
                        Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Tile.Value,
                                                 Mode=OneWay}">
                        <MenuItem.Icon>
                            <Path
                                Width="13"
                                Height="10.40"
                                Data="{StaticResource PanoramaGeometry}"
                                Fill="{DynamicResource MainTextColor}"
                                Stretch="Fill" />
                        </MenuItem.Icon>
                    </MenuItem>
                </MenuItem>

                <MenuItem
                    x:Name="CopyFile"
                    Click="CopyFile_OnClick"
                    Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.CopyFile.Value,
                                             Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path
                            Width="12"
                            Height="12"
                            Data="{StaticResource CopyGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Stretch="Fill" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    x:Name="CopyImage"
                    Click="CopyImage_OnClick"
                    Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.CopyImage.Value,
                                             Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path
                            Width="12"
                            Height="12"
                            Data="{StaticResource CopyGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Stretch="Fill" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem x:Name="CopyBase64" Click="CopyBase64_OnClick">
                    <MenuItem.Header>
                        <TextBlock>
                            <Run Text="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Copy.Value, Mode=OneWay}" />
                            <Run Text=" base64" />
                        </TextBlock>
                    </MenuItem.Header>
                    <MenuItem.Icon>
                        <Path
                            Width="12"
                            Height="12"
                            Data="{StaticResource CopyGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Stretch="Fill" />
                    </MenuItem.Icon>
                </MenuItem>

                <MenuItem
                    x:Name="DuplicateFile"
                    Click="DuplicateFile_OnClick"
                    Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.DuplicateFile.Value,
                                             Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path
                            Width="12"
                            Height="12"
                            Data="{StaticResource CopyGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Stretch="Fill" />
                    </MenuItem.Icon>
                </MenuItem>

                <Separator />

                <MenuItem
                    x:Name="DeleteFile"
                    Click="DeleteFile_OnClick"
                    Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.DeleteFile.Value,
                                             Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path
                            Width="12"
                            Height="12"
                            Data="{StaticResource RecycleGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Stretch="Fill" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Header="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Stretch.Value, Mode=OneWay}" IsVisible="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).WindowTabs.ActiveTab.Value.Gallery.IsGalleryExpanded.Value}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource Image}" />
                    </MenuItem.Icon>
                    <MenuItem
                        Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.SetExpandedStretchModeCommand}"
                        CommandParameter="{x:Static gallerySettings:GalleryStretchMode.Uniform}"
                        Header="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Uniform.Value, Mode=OneWay}"
                        IsChecked="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.IsExpandedStretchUniform.Value}"
                        ToggleType="Radio" />
                    <MenuItem
                        Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.SetExpandedStretchModeCommand}"
                        CommandParameter="{x:Static gallerySettings:GalleryStretchMode.UniformToFill}"
                        Header="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.UniformToFill.Value, Mode=OneWay}"
                        IsChecked="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.IsExpandedStretchUniformToFill.Value}"
                        ToggleType="Radio" />
                    <MenuItem
                        Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.SetExpandedStretchModeCommand}"
                        CommandParameter="{x:Static gallerySettings:GalleryStretchMode.Fill}"
                        Header="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Fill.Value, Mode=OneWay}"
                        IsChecked="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.IsExpandedStretchToFill.Value}"
                        ToggleType="Radio" />
                    <MenuItem
                        Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.SetExpandedStretchModeCommand}"
                        CommandParameter="{x:Static gallerySettings:GalleryStretchMode.None}"
                        Header="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.None.Value, Mode=OneWay}"
                        IsChecked="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.IsExpandedStretchNone.Value}"
                        ToggleType="Radio" />
                    <MenuItem
                        Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.SetExpandedStretchModeCommand}"
                        CommandParameter="{x:Static gallerySettings:GalleryStretchMode.Square}"
                        Header="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Square.Value, Mode=OneWay}"
                        IsChecked="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.IsExpandedStretchSquare.Value}"
                        ToggleType="Radio" />
                    <MenuItem
                        Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.SetExpandedStretchModeCommand}"
                        CommandParameter="{x:Static gallerySettings:GalleryStretchMode.FillSquare}"
                        Header="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.FillSquare.Value, Mode=OneWay}"
                        IsChecked="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.IsExpandedStretchSquareFill.Value}"
                        ToggleType="Radio" />
                </MenuItem>
                <MenuItem Header="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Stretch.Value, Mode=OneWay}" IsVisible="{CompiledBinding !$parent[Window].((viewModels:MainWindowViewModel)DataContext).WindowTabs.ActiveTab.Value.Gallery.IsGalleryExpanded.Value}">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource Image}" />
                    </MenuItem.Icon>
                    <MenuItem
                        Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.SetDockedStretchModeCommand}"
                        CommandParameter="{x:Static gallerySettings:GalleryStretchMode.Uniform}"
                        Header="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Uniform.Value, Mode=OneWay}"
                        IsChecked="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.IsDockedStretchUniform.Value}"
                        ToggleType="Radio" />
                    <MenuItem
                        Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.SetDockedStretchModeCommand}"
                        CommandParameter="{x:Static gallerySettings:GalleryStretchMode.UniformToFill}"
                        Header="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.UniformToFill.Value, Mode=OneWay}"
                        IsChecked="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.IsDockedStretchUniformToFill.Value}"
                        ToggleType="Radio" />
                    <MenuItem
                        Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.SetDockedStretchModeCommand}"
                        CommandParameter="{x:Static gallerySettings:GalleryStretchMode.Fill}"
                        Header="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Fill.Value, Mode=OneWay}"
                        IsChecked="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.IsDockedStretchToFill.Value}"
                        ToggleType="Radio" />
                    <MenuItem
                        Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.SetDockedStretchModeCommand}"
                        CommandParameter="{x:Static gallerySettings:GalleryStretchMode.None}"
                        Header="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.None.Value, Mode=OneWay}"
                        IsChecked="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.IsDockedStretchNone.Value}"
                        ToggleType="Radio" />
                    <MenuItem
                        Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.SetDockedStretchModeCommand}"
                        CommandParameter="{x:Static gallerySettings:GalleryStretchMode.Square}"
                        Header="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.Square.Value, Mode=OneWay}"
                        IsChecked="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.IsDockedStretchSquare.Value}"
                        ToggleType="Radio" />
                    <MenuItem
                        Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.SetDockedStretchModeCommand}"
                        CommandParameter="{x:Static gallerySettings:GalleryStretchMode.FillSquare}"
                        Header="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.FillSquare.Value, Mode=OneWay}"
                        IsChecked="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).GallerySettings.IsDockedStretchSquareFill.Value}"
                        ToggleType="Radio" />
                </MenuItem>
                <MenuItem
                    Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.ExpandedGalleryItemSize.Value,
                                             Mode=OneWay}"
                    PointerPressed="Flyout_OnPointerPressed"
                    StaysOpenOnClick="True">
                    <MenuItem.Icon>
                        <Image
                            Width="12"
                            Height="12"
                            Source="{StaticResource Image}" />
                    </MenuItem.Icon>
                    <FlyoutBase.AttachedFlyout>
                        <Flyout>
                            <Border
                                Padding="10,3"
                                Background="{DynamicResource MainButtonBackgroundColor}"
                                BorderBrush="{DynamicResource MainBorderColor}"
                                BorderThickness="2"
                                CornerRadius="4">
                                <gallery:GalleryItemSizeSlider x:Name="GalleryItemSizeSlider" />
                            </Border>
                        </Flyout>
                    </FlyoutBase.AttachedFlyout>
                </MenuItem>
                <Separator />
                <MenuItem Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).WindowTabs.ActiveTab.Value.Gallery.ToggleGalleryCommand}" Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.ShowImageGallery.Value, Mode=OneWay}">
                    <MenuItem.Icon>
                        <Path
                            Width="12"
                            Height="12"
                            Data="{StaticResource GalleryGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Stretch="Fill" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem
                    Command="{Binding $parent[Window].((viewModels:MainWindowViewModel)DataContext).WindowTabs.ActiveTab.Value.Gallery.ContractToDockedOrCloseGalleryCommand}"
                    Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.HideDockedGallery.Value,
                                             Mode=OneWay}"
                    IsVisible="{CompiledBinding !$parent[Window].((viewModels:MainWindowViewModel)DataContext).WindowTabs.ActiveTab.Value.Gallery.IsGalleryExpanded.Value}">
                    <MenuItem.Icon>
                        <Path
                            Width="12"
                            Height="12"
                            Data="{StaticResource CloseGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Stretch="Fill" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem
                    Command="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).WindowTabs.ActiveTab.Value.Gallery.ContractToDockedOrCloseGalleryCommand}"
                    Header="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).Translation.CloseGallery.Value,
                                             Mode=OneWay}"
                    IsVisible="{CompiledBinding $parent[Window].((viewModels:MainWindowViewModel)DataContext).WindowTabs.ActiveTab.Value.Gallery.IsGalleryExpanded.Value}">
                    <MenuItem.Icon>
                        <Path
                            Width="12"
                            Height="12"
                            Data="{StaticResource CloseGeometry}"
                            Fill="{DynamicResource MainTextColor}"
                            Stretch="Fill" />
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </Border.ContextMenu>
    </Border>
</customControls:NavigateAbleItem>
