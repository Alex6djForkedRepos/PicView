<UserControl
    Height="300"
    Width="300"
    x:Class="PicView.Avalonia.CustomControls.AnalogClock"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Panel>
        <Border
            Background="{DynamicResource MainBackgroundColor}"
            BorderBrush="{DynamicResource MainBorderColor}"
            BorderThickness="1"
            CornerRadius="150"
            x:Name="CircularBorder">
            <Panel x:Name="MainPanel">
                <Ellipse
                    Fill="{DynamicResource MainTextColorFaded}"
                    Height="20"
                    StrokeThickness="2"
                    Width="20" />

                <TextBlock
                    Classes="txt txtShadow"
                    FontSize="14"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    ZIndex="1"
                    x:Name="DigitalTime" />
            </Panel>
        </Border>
    </Panel>
</UserControl>
